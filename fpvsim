local function getLocalRoot()
    local c=plr.Character;local h=c and c:FindFirstChild("HumanoidRootPart")
    return h and h.Position
end
local function filterByDist(mp)
    local l={}
    for _,o in ipairs(Players:GetPlayers()) do
        if o~=plr and o.Character then
            local h=o.Character:FindFirstChild("HumanoidRootPart")
            if h and(h.Position-mp).Magnitude>50 then table.insert(l,o) end
        end
    end
    return l
end
local function tryForPrimary(d)
    if d.PrimaryPart then return true end
    for _,c in ipairs(d:GetDescendants()) do
        if c:IsA("BasePart") then d.PrimaryPart=c;return true end
    end
    return false
end
local function firstPartPos(d)
    if d.PrimaryPart then return d.PrimaryPart.Position end
    for _,c in ipairs(d:GetDescendants()) do
        if c:IsA("BasePart") then return c.Position end
    end
end
local function collectDrones()
    local l={}
    for _,o in ipairs(workspace:GetChildren()) do
        if o:IsA("Model") and o.Name:match("_ActiveDrone$") then table.insert(l,o) end
    end
    return l
end

local function solveForDrop(tpos, tvel)
    local cp = cam.CFrame.Position
    local dir = tpos - cp
    local dist = dir.Magnitude
    local vH = Vector3.new(dir.X, 0, dir.Z).Magnitude
    local g = workspace.Gravity
    local bulletForce = 800
    local effectiveGravity = math.max(g - bulletForce, 0)
    local dy = tpos.Y - cp.Y
    local tof = dist / 884

    for i = 1, 5 do
        local drop = 0.5 * effectiveGravity * tof * tof
        local needY = dy + drop
        local totalDist = math.sqrt(vH * vH + needY * needY)
        tof = totalDist / 884
    end

    local lead = Vector3.zero
    if tvel and tvel.Magnitude > 0.5 then lead = tvel * tof end
    local drop = 0.5 * effectiveGravity * tof * tof
    return tpos + lead + Vector3.new(0, drop, 0)
end

local function addDroneHL(d)
    if espHL[d] then return end
    local h=Instance.new("Highlight")
    h.FillColor=Color3.fromRGB(255,50,50);h.FillTransparency=0.75
    h.OutlineColor=Color3.fromRGB(255,50,50);h.OutlineTransparency=0
    h.Parent=d;espHL[d]=h
end
local function clearDeadHL()
    for d,h in pairs(espHL) do
        if not d.Parent then pcall(function()h:Destroy()end);espHL[d]=nil end
    end
end

local function createEspFor(p)
    if p==plr or espGui[p] then return end
    local ch=p.Character;if not ch then return end
    local hl=Instance.new("Highlight")
    hl.FillColor=Color3.fromRGB(255,255,255);hl.FillTransparency=0.8
    hl.OutlineColor=Color3.fromRGB(255,255,255);hl.OutlineTransparency=0.2
    hl.Adornee=ch;hl.Parent=ch
    local head=ch:FindFirstChild("Head");if not head then return end
    local bb=Instance.new("BillboardGui")
    bb.Size=UDim2.new(0,100,0,30);bb.StudsOffset=Vector3.new(0,2.5,0)
    bb.AlwaysOnTop=true;bb.Parent=head
    local lb=Instance.new("TextLabel")
    lb.Size=UDim2.new(1,0,0.5,0);lb.BackgroundTransparency=1
    lb.TextColor3=Color3.fromRGB(255,255,255);lb.TextStrokeTransparency=0
    lb.Font=Enum.Font.Code;lb.TextScaled=true;lb.Text=p.Name;lb.Parent=bb
    local hp=Instance.new("TextLabel")
    hp.Size=UDim2.new(1,0,0.4,0);hp.Position=UDim2.new(0,0,0.55,0)
    hp.BackgroundTransparency=1;hp.TextColor3=Color3.fromRGB(100,255,100)
    hp.TextStrokeTransparency=0;hp.Font=Enum.Font.Code;hp.TextScaled=true;hp.Parent=bb
    local bg=Instance.new("Frame")
    bg.Size=UDim2.new(0.8,0,0,3);bg.Position=UDim2.new(0.1,0,1,-1)
    bg.BackgroundColor3=Color3.fromRGB(40,40,40);bg.BorderSizePixel=0;bg.Parent=bb
    local bf=Instance.new("Frame")
    bf.Size=UDim2.new(1,0,1,0);bf.BackgroundColor3=Color3.fromRGB(100,255,100)
    bf.BorderSizePixel=0;bf.Parent=bg
    espGui[p]={hl=hl,bb=bb,label=lb,hpLabel=hp,barFill=bf}
end
local function refreshEspFor(p,mp)
    local d=espGui[p];if not d then return end
    local ch=p.Character
    if not ch or not ch:FindFirstChild("Head") then
        pcall(function()d.hl:Destroy()end);pcall(function()d.bb:Destroy()end)
        espGui[p]=nil;return
    end
    local hrp=ch:FindFirstChild("HumanoidRootPart")
    local hum=ch:FindFirstChildOfClass("Humanoid")
    local dist=hrp and mp and(hrp.Position-mp).Magnitude or 0
    if hum then
        local pct=hum.MaxHealth>0 and hum.Health/hum.MaxHealth or 0
        d.hpLabel.Text=string.format("%.0f | %.0f",dist,hum.Health)
        d.barFill.Size=UDim2.new(math.clamp(pct,0,1),0,1,0)
        d.barFill.BackgroundColor3=pct>0.5 and Color3.fromRGB(100,255,100)
            or pct>0.25 and Color3.fromRGB(255,200,50)or Color3.fromRGB(255,50,50)
    else d.hpLabel.Text=string.format("%.0f",dist) end
end
local function clearDeadEsp()
    for p,d in pairs(espGui) do
        if not p.Parent or not p.Character then
            pcall(function()d.hl:Destroy()end);pcall(function()d.bb:Destroy()end)
            espGui[p]=nil
        end
    end
end

local function findClosestInFov(drones)
    local vp=cam.ViewportSize;local cx,cy=vp.X/2,vp.Y/2
    local best,bd=nil,90
    for _,dr in ipairs(drones) do
        if dr.Name==myDroneName then continue end
        local p=firstPartPos(dr);if not p then continue end
        local sp,on=cam:WorldToViewportPoint(p)
        if on and sp.Z>0 then
            local sd=math.sqrt((sp.X-cx)^2+(sp.Y-cy)^2)
            if sd<bd then
                bd=sd
                local dv=Vector3.zero
                local r=dr.PrimaryPart
                if r then dv=r.AssemblyLinearVelocity or Vector3.zero end
                best={name=dr.Name:match("(.+)_ActiveDrone")or"?",pos=p,vel=dv,sx=sp.X,sy=sp.Y}
            end
        end
    end
    if not best then
        for _,o in ipairs(Players:GetPlayers()) do
            if o==plr then continue end
            local ch=o.Character;if not ch then continue end
            local head=ch:FindFirstChild("Head")
            local hrp=ch:FindFirstChild("HumanoidRootPart")
            local hum=ch:FindFirstChildOfClass("Humanoid")
            if not head or not hrp then continue end
            if hum and hum.Health<=0 then continue end
            local sp,on=cam:WorldToViewportPoint(head.Position)
            if on and sp.Z>0 then
                local sd=math.sqrt((sp.X-cx)^2+(sp.Y-cy)^2)
                if sd<bd then
                    bd=sd
                    best={name=o.Name,pos=head.Position,
                        vel=hrp.AssemblyLinearVelocity or Vector3.zero,sx=sp.X,sy=sp.Y}
                end
            end
        end
    end
    return best
end

local function cacheForRollback(obj,key)
    if not saved[key] then
        if obj:IsA("BasePart") then saved[key]=obj.CFrame
        elseif obj:IsA("Model") then saved[key]=obj:GetPivot() end
    end
end
local function rollbackCached()
    for key,cf in pairs(saved) do
        local t,n=key:match("^(.-)_(.+)$")
        if t=="head" then
            for _,p in ipairs(Players:GetPlayers()) do
                if p.Name==n and p~=plr and p.Character then
                    local h=p.Character:FindFirstChild("Head")
                    if h then h.CFrame=cf end
                end
            end
        elseif t=="drone" then
            local d=workspace:FindFirstChild(n)
            if d and d:IsA("Model") then d:PivotTo(cf) end
        end
    end
    saved={}
end
local function pullToCamera()
    local pt=cam.CFrame.Position+cam.CFrame.LookVector*8
    for _,o in ipairs(Players:GetPlayers()) do
        if o==plr then continue end
        local ch=o.Character;if not ch then continue end
        local head=ch:FindFirstChild("Head");if not head then continue end
        local hum=ch:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health<=0 then continue end
        cacheForRollback(head,"head_"..o.Name)
        head.CFrame=CFrame.new(pt)
    end
    for _,obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj.Name:match("_ActiveDrone$") and obj.Name~=game.PO"_ActiveDrone" then
            tryForPrimary(obj);cacheForRollback(obj,"drone_"..obj.Name)
            obj:PivotTo(CFrame.new(pt))
        end
    end
end

table.insert(conns,Run.Heartbeat:Connect(function()
    if not active then return end
    local now=tick()
    local mp=getLocalRoot()
    local vp=cam.ViewportSize
    fov.Position=UDim2.new(0,vp.X/2,0,vp.Y/2)

    clearDeadHL()
    for _,d in ipairs(collectDrones()) do tryForPrimary(d);addDroneHL(d) end
    clearDeadEsp()
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=plr and p.Character then createEspFor(p);refreshEspFor(p,mp) end
    end

    if now-lastTP>=0.5 and mp then
        local md=workspace:FindFirstChild(myDroneName)
        if md and tryForPrimary(md) then
            local far=filterByDist(mp)
            if #far>0 then
                local t=far[math.random(1,#far)]
                local h=t.Character and t.Character:FindFirstChild("HumanoidRootPart")
                if h then md:PivotTo(h.CFrame);lastTP=now end
            end
        end
    end

    if UIS:IsKeyDown(Enum.KeyCode.X) then
        if now-lastMag>=0.05 then pullToCamera();lastMag=now;magOn=true end
    else
        if magOn then rollbackCached();magOn=false end
    end

    if UIS:IsKeyDown(Enum.KeyCode.LeftAlt) then
        fovS.Color=Color3.fromRGB(255,80,80);fovS.Thickness=2
        local tgt=findClosestInFov(collectDrones())
        if tgt then
            local ap=solveForDrop(tgt.pos,tgt.vel)
            aimLbl.Visible=true;aimLbl.Text=tgt.name
            aimLbl.Position=UDim2.new(0,tgt.sx,0,tgt.sy-18)
            cam.CFrame=cam.CFrame:Lerp(CFrame.lookAt(cam.CFrame.Position,ap),0.25)
        else aimLbl.Visible=false end
    else
        fovS.Color=Color3.fromRGB(220,220,220);fovS.Thickness=1.5
        aimLbl.Visible=false
    end
	if UIS:IsKeyDown(Enum.KeyCode.P) then
	plr.Character.HumanoidRootPart.CFrame = CFrame.new(-737.114075, 194.380035, 245.213043, 0.0609416142, -3.90129884e-08, 0.998141348, 3.75203832e-08, 1, 3.67948267e-08, -0.998141348, 3.52083092e-08, 0.0609416142)
    end
end))

