table.insert(conns,UIS.InputBegan:Connect(function(inp,gp)
    if gp then return end
    if inp.KeyCode==Enum.KeyCode.End then
        active=false
        if magOn then rollbackCached() end
        for _,c in ipairs(conns) do pcall(function()c:Disconnect()end) end
        for _,h in pairs(espHL) do pcall(function()h:Destroy()end) end
        for _,d in pairs(espGui) do
            pcall(function()d.hl:Destroy()end);pcall(function()d.bb:Destroy()end)
        end
        pcall(function()gui:Destroy()end)
    end
end))
