    Title = "Max Strength",
    Desc = "",
    Icon = "bird",
    Type = "Checkbox",
    Default = false,
    Callback = function(state) 
        strengthEnabled = state
    end
})

local autokillToggle = mainTab:Toggle({
    Title = "Auto Kill",
    Desc = "",
    Icon = "bird",
    Type = "Checkbox",
    Default = false,
    Callback = function(state) 
        AutoKillEnabled = state
    end
})

local palletBind = mainTab:Keybind({
    Title = "Place pallet under you",
    Desc = "Bind",
    Value = "T",
    Callback = function(v)
        if hrp then
            game:GetService("ReplicatedStorage"):WaitForChild("MenuToys"):WaitForChild("SpawnToyRemoteFunction"):InvokeServer(unpack({"PalletLightBrown",CFrame.new(hrp.CFrame.X, hrp.CFrame.Y-2, hrp.CFrame.Z+20),Vector3.new(0, 0, 0)}))
        end
    end
})

local skyboxDropdown = visualTab:Dropdown({
    Title = "Skybox",
    Values = { "Halloween orange", "Grey", "Red Blood", "Abysall Blue", "Caged Beast Blue", "Toxic Clouds Green" },
    v = "",
    Callback = function(v) 
        if v == 'Halloween orange' then
            hallowenSkybox()
        elseif v == 'Grey' then
            greySkybox()
        elseif v == 'Red Blood' then
            redBloodSkybox()
        elseif v == 'Abysall Blue' then
            abysallblueSkybox()
        elseif v == 'Caged Beast Blue' then
            cagedbeastSkybox()
        elseif v == 'Toxic Clouds Green' then
            toxiccloudsSkybox()
        end
    end
})

local oceanColorpicker = visualTab:Colorpicker({
    Title = "Ocean color",
    Desc = "",
    Default = Color3.fromRGB(0, 255, 0),
    Transparency = 0,
    Locked = false,
    Callback = function(color) 
        for _, oceanpart in pairs(workspace.Map.AlwaysHereTweenedObjects.Ocean.Object.ObjectModel:GetChildren()) do
            oceanpart.Color = color
        end
    end
})

local treeColorpicker = visualTab:Colorpicker({
    Title = "Grass color",
    Desc = "",
    Default = Color3.fromRGB(0, 255, 0),
    Transparency = 0,
    Locked = false,
    Callback = function(color) 
        for _, grasspart in pairs(workspace.Map:GetDescendants()) do
            if string.find(string.lower(grasspart.Name), 'grass') then
                if grasspart:IsA('Part') or grasspart:IsA('CornerWedgePart') then
                    grasspart.Color = color
                end
            end
        end
    end
})

local rockColorpicker = visualTab:Colorpicker({
    Title = "Rock color",
    Desc = "",
    Default = Color3.fromRGB(0, 255, 0),
    Transparency = 0,
    Locked = false,
    Callback = function(color) 
        for _, grasspart in pairs(workspace.Map:GetDescendants()) do  
            if grasspart.Name == 'Rock' or grasspart.Name == 'Dirt' and grasspart:IsA('Part') or grasspart:IsA('MeshPart') then
                grasspart.Color = color
            end
        end
    end
})

local treeRemoverButton = visualTab:Button({
    Title = "Remove trees",
    Desc = "",
    Locked = false,
    Callback = function()
        workspace.Map.MapProps:Destroy()
        workspace.Plots.Plot5.House.SakuraTree:Destroy()
        workspace.Plots.Plot5.House:GetChildren()[4]:Destroy()
    end
})

local timeSlider = visualTab:Slider({
    Title = "Time",
