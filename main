    },
    Callback = function(value)
        game:GetService("Lighting").FogEnd = value
    end
})


local fogColorpicker = visualTab:Colorpicker({
    Title = "Fog color",
    Desc = "",
    Default = Color3.fromRGB(255, 255, 255),
    Transparency = 0,
    Locked = false,
    Callback = function(color) 
        game:GetService("Lighting").FogColor = color
    end
})

spawn(function()
    while true do
        if lockEnabled then
            lockOnTarget()
        elseif strengthEnabled then
            SetMaxResponse()
        elseif AutoKillEnabled then
            AutoKill()
        end
        wait(0.1)
    end
end)

plrs.PlayerAdded:Connect(function()
    if specificTargetEnabled then
        targetDropdown:Refresh(GetPlayers())
    end
end)

plrs.PlayerRemoving:Connect(function()
    if specificTargetEnabled then
        targetDropdown:Refresh(GetPlayers())
    end
end)
