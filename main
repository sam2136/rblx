-- Skyboxes -- 
loadstring(game:HttpGet("https://raw.githubusercontent.com/sam2136/rblx/refs/heads/main/skyboxes"))()

-- Ingame locals --

local plrs = game.Players
local plr = plrs.LocalPlayer
local char = plr.Character or plr.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
-- Mouse --

local mouse = plr:GetMouse()
local camera = workspace.CurrentCamera

-- Services --

local UIS = game:GetService("UserInputService")

-- Variables --

local AutoKillEnabled = false
local strengthEnabled = false
local lockEnabled = false
local specificTargetEnabled = false
local selectedTarget = nil
local teleportDebounce = {}
-- Update character references on respawn
plr.CharacterAdded:Connect(function(newChar)
    char = newChar
    hrp = newChar:WaitForChild("HumanoidRootPart")
end)

-- Functions --
local function GetPlayers()
    local dd_array = {}
    for _, v in pairs(plrs:GetChildren()) do
        if v.Name ~= plr.Name then
            table.insert(dd_array, v.Name)
        end
    end
    return dd_array
end

local function isPlayerHeld(player)
    if player and player:FindFirstChild("IsHeld") then
        return player.IsHeld.Value
    end
    return false
end

local function findNearbyPlayer()
    if not char or not hrp then 
        char = plr.Character
        if char then
            hrp = char:FindFirstChild("HumanoidRootPart")
        end
        if not char or not hrp then return end
    end
    
    local myPos = hrp.Position
    
    if specificTargetEnabled and selectedTarget then
        local targetPlayer = plrs:FindFirstChild(selectedTarget)
        if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            if not isPlayerHeld(targetPlayer) then
                return targetPlayer.Character
            end
        end
        return nil
    end
    
    for _, player in pairs(plrs:GetPlayers()) do
        if player ~= plr and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            if not isPlayerHeld(player) then
                local targetPos = player.Character.HumanoidRootPart.Position
                local distance = (myPos - targetPos).Magnitude
                
                if distance <= 18 then
                    return player.Character
                end
            end
        end
    end
    return nil
end

local function SetMaxResponse()
    local success, result = pcall(function()
        local gps = workspace:FindFirstChild("GrabParts")
        if gps then
            local dp = gps:FindFirstChild("DragPart")
            if dp then
                local ap = dp:FindFirstChild("AlignPosition")
                if ap then
                    ap.Responsiveness = 200
                    return true
                end
            end
        end
        return false
    end)
    
    if not success then
        print("Error in SetMaxResponse:", result)
    end
end


local function AutoKill()
    local gps = workspace:FindFirstChild("GrabParts")
    if not gps then return end
    
    local gp = gps:FindFirstChild("DragPart")
    if not gp then return end
    gp.CanCollide = true
    -- 2. Получаем список всех деталей, которые СЕЙЧАС касаются нашего триггера
    local touchingParts = gp:GetTouchingParts()

    -- 3. Проходимся по каждой коснувшейся детали
    for _, part in pairs(touchingParts) do
        local character = part.Parent
        local player = plrs:GetPlayerFromCharacter(character) -- plrs - ваша глобальная переменная

        -- 4. Проверяем, что это игрок, и это не мы (plr - ваша глобальная переменная)
        if player and player ~= plr then
            
            -- 5. Проверяем debounce: если мы только что его телепортировали, переходим к следующей детали
            if teleportDebounce[player.UserId] then continue end

            local targetHrp = character:FindFirstChild("HumanoidRootPart")
            if targetHrp then
                print("Обнаружено касание от " .. player.Name .. ". Телепортирую.")
                
                -- Отмечаем, что мы телепортируем этого игрока
                teleportDebounce[player.UserId] = true

                -- 6. Телепортируем его в нужную точку
                targetHrp.CFrame = CFrame.new(-930.202515, -98.6741409, -92.9015274, 0.136398539, -1.79208914e-08, 0.990654051, -3.79907767e-08, 1, 2.3320732e-08, -0.990654051, -4.08166301e-08, 0.136398539)
                
                -- Через секунду разрешаем снова его телепортировать
                task.wait(1)
                teleportDebounce[player.UserId] = nil

                -- 7. Выходим из цикла, так как мы уже обработали одного игрока в этом кадре
                break
            end
        end
    end
end

local function lockOnTarget()
    if not lockEnabled then return end
    
    local target = findNearbyPlayer()
    if target and target:FindFirstChild("HumanoidRootPart") then
        local originalCFrame = camera.CFrame  
        camera.CFrame = CFrame.lookAt(camera.CFrame.Position, target.HumanoidRootPart.Position)
        wait(0.05)
        mouse1click()
        wait(0.05)
        camera.CFrame = originalCFrame
    end
end

