})

-- Binds Buttons --
local toggleWindowBind = extrasTab:Keybind({
    Title = "Windows toggle bind",
    Desc = "Bind",
    Value = "F1",
    Callback = function(v)
        Window:Toggle()
    end
})

local lockNearestEnemyToggle = mainTab:Toggle({
    Title = "Lock nearest enemy",
    Desc = "",
    Icon = "bird",
    Type = "Checkbox",
    Default = false,
    Callback = function(state) 
        lockEnabled = state
    end
})

local targetDropdown = mainTab:Dropdown({
    Title = "Target player: ",
    Values = GetPlayers(),
    Value = "None",
    Callback = function(option) 
        selectedTarget = option
    end
})

local specificTargetToggle = mainTab:Toggle({
    Title = "Target specific player",
    Desc = "Only target selected player",
    Icon = "target",
    Type = "Checkbox",
    Default = false,
    Callback = function(state) 
        specificTargetEnabled = state
        if state then
            targetDropdown:Refresh(GetPlayers())
        end
    end
})

